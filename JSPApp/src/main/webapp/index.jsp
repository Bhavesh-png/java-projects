public class StudentBean {

// Private variables
private int id;
private String name;
private int age;

// Default constructor
public StudentBean() {}

// Getter and Setter methods

public void setId(int id) {
this.id = id;
}

public int getId() {
return id;
}

public void setName(String name) {
this.name = name;
}

public String getName() {
return name;
}

public void setAge(int age) {
this.age = age;
}

public int getAge() {
return age;
}
}